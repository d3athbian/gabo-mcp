{
  "name": "gabo-mcp",
  "version": "1.0.0",
  "description": "Personal MCP server for capturing, structuring, and reusing technical knowledge",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.7.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:test": "NODE_ENV=test node --env-file=.env scripts/test-db.js"
  },
  "keywords": ["mcp", "knowledge", "semantic-search", "ai", "embeddings"],
  "author": "@gabo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@supabase/supabase-js": "^2.38.0"
  }
}

