{
  "name": "gabo-mcp",
  "version": "1.4.0",
  "description": "Personal MCP server for capturing, structuring, and reusing technical knowledge",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.7.0"
  },
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "dev:local": "NODE_ENV=development tsx src/index.ts",
    "dev:inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "build": "tsc && mkdir -p dist/prompts/templates && cp src/prompts/templates/*.md dist/prompts/templates/",
    "start": "node --env-file=.env dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:key": "tsx scripts/generate-key.ts",
    "db:backup": "tsx scripts/backup-db.ts --force"
  },
  "keywords": [
    "mcp",
    "knowledge",
    "semantic-search",
    "ai",
    "embeddings"
  ],
  "author": "@gabo",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "mongodb": "^7.0.0",
    "zod": "^3.22.0"
  }
}
