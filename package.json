{
  "name": "gabo-mcp",
  "version": "1.0.0",
  "description": "Personal MCP server for capturing, structuring, and reusing technical knowledge",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:test": "NODE_ENV=test node scripts/test-db.js"
  },
  "keywords": ["mcp", "knowledge", "semantic-search", "ai", "embeddings"],
  "author": "@gabo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/ui": "^1.1.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@supabase/supabase-js": "^2.38.0",
    "dotenv": "^16.3.1"
  }
}

