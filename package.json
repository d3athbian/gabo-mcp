{
  "name": "gabo-mcp",
  "version": "1.0.0",
  "description": "Personal MCP server for capturing, structuring, and reusing technical knowledge",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.7.0"
  },
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "dev:local": "./scripts/emergency-clean.sh && NODE_ENV=development tsx src/index.ts",
    "dev:inspector": "./scripts/emergency-clean.sh && npx @modelcontextprotocol/inspector tsx src/index.ts",
    "clean": "./scripts/emergency-clean.sh",
    "prestart": "./scripts/emergency-clean.sh",
    "kill:zombies": "./scripts/emergency-clean.sh",
    "kill:all": "./scripts/emergency-clean.sh",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --fix",
    "test": "./scripts/emergency-clean.sh && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "knowledge",
    "semantic-search",
    "ai",
    "embeddings"
  ],
  "author": "@gabo",
  "license": "MIT",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.0.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@supabase/supabase-js": "^2.38.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "mongodb": "^7.0.0",
    "zod": "^3.22.0"
  }
}
