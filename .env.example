NODE_ENV=development
LOG_LEVEL=debug

# MongoDB Atlas (M0 Free Tier)
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/knowledge_mcp?retryWrites=true&w=majority

# NOTE: MongoDB Atlas M0 Free Tier includes:
# - 512 MB storage (enough for 60,000+ entries)
# - Vector Search (768 dimensions, cosine similarity)
# - 500 max connections
# - 10 GB data transfer/week

# Embeddings - Local Ollama
EMBED_MODEL=nomic-embed-text
OLLAMA_API_URL=http://localhost:11434
EMBED_BATCH_SIZE=32
EMBED_CACHE_DIR=./cache/embeddings
EMBED_CACHE_ENABLED=true

# Alternative: OpenAI embeddings (optional for Phase 4+)
# EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MCP Server
MCP_SERVER_PORT=3000
MCP_REQUEST_TIMEOUT=30000
MAX_CONTEXT_LENGTH=2048

# API Key Authentication (REQUIRED)
# Run 'create_first_api_key' tool to generate your first key
# Format: gmcp_live_<32_random_chars>
MCP_API_KEY=gmcp_live_your_key_here

# External API Keys (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Feature Flags
ENABLE_EMBEDDINGS=true
ENABLE_CACHE=true
ENABLE_AUDIT_LOG=true

# Development
DEBUG=false
PRETTY_LOGS=true

# ============================================================================
# SECURITY PROFILE
# ============================================================================
# Controls what types of content are blocked from being stored
# Options: work | personal
#
# work: Maximum security
#   - Blocks: corporate data, user data, credentials, PII, environment variables
#   - Use this profile when working with company code or sensitive projects
#
# personal: Standard security  
#   - Blocks: credentials, tokens, API keys, critical PII
#   - Use this profile for personal projects
#
SECURITY_PROFILE=personal
