NODE_ENV=development
LOG_LEVEL=debug

# MongoDB Atlas (M0 Free Tier)
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/knowledge_mcp?retryWrites=true&w=majority

# NOTE: MongoDB Atlas M0 Free Tier includes:
# - 512 MB storage (enough for 60,000+ entries)
# - Vector Search (768 dimensions, cosine similarity)
# - 500 max connections
# - 10 GB data transfer/week

# Embeddings - Local Ollama
EMBED_MODEL=nomic-embed-text
OLLAMA_API_URL=http://localhost:11434
EMBED_BATCH_SIZE=32
EMBED_CACHE_DIR=./cache/embeddings
EMBED_CACHE_ENABLED=true

# Alternative: OpenAI embeddings (optional for Phase 4+)
# EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MCP Server
MCP_SERVER_PORT=3000
MCP_REQUEST_TIMEOUT=30000
MAX_CONTEXT_LENGTH=2048

# User ID (for development/testing - replace with auth in production)
# This simulates the authenticated user ID
DEV_USER_ID=dev-user-123

# API Keys (for future phases)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Feature Flags
ENABLE_EMBEDDINGS=true
ENABLE_CACHE=true
ENABLE_AUDIT_LOG=true

# Development
DEBUG=false
PRETTY_LOGS=true
