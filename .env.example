# =============================================================================
# MongoDB - REQUERIDO
# =============================================================================
# Connection string a MongoDB Atlas o local
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/knowledge_mcp

# =============================================================================
# Autenticación - Opcional (auto-generado en primer inicio)
# =============================================================================
# Pepper para bcrypt hashing - AUTO-GENERADO, no modificar después de creado
# MCP_KEY_PEPPER=

# API Key para autenticar requests - AUTO-GENERADO, no modificar después de creado
# MCP_API_KEY=

# =============================================================================
# Entorno - Opcional
# =============================================================================
# NODE_ENV=development  # development | production | test

# =============================================================================
# Logging - Opcional
# =============================================================================
# LOG_LEVEL=info  # debug | info | warn | error
# DEBUG=false
# PRETTY_LOGS=false

# =============================================================================
# Features - Opcional
# =============================================================================
# ENABLE_CACHE=true
# ENABLE_AUDIT_LOG=true

# =============================================================================
# Embeddings - Opcional
# =============================================================================
# EMBED_ENABLED=true
# EMBED_PROVIDER=ollama  # ollama | openai
# EMBED_MODEL=nomic-embed-text
# EMBED_OLLAMA_URL=http://localhost:11434
# EMBED_AUTO_START=true

# =============================================================================
# Health Check - Opcional
# =============================================================================
# HEALTH_CHECK_ENABLED=true

# =============================================================================
# MCP Server - Opcional
# =============================================================================
# MCP_SERVER_PORT=3000
# MCP_REQUEST_TIMEOUT=30000
# MAX_CONTEXT_LENGTH=2048
