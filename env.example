# MongoDB Atlas - Obligatorio
# Obtén tu connection string en: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/knowledge_mcp?retryWrites=true&w=majority

# Pepper para bcrypt hashing de API Keys
# NO cambiar una vez creado (invalida todos los hashes)
MCP_KEY_PEPPER=your-pepper-here

# API Key - Genera con: npm run generate:key
MCP_API_KEY=gabo_xxxxxxxxxxxxxxxx

# === Opcionales ===

# Configuración de embeddings
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_ENABLED=true

# URL de Ollama (si usas embeddings)
OLLAMA_BASE_URL=http://localhost:11434

# Health check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_MS=30000

# Retención de logs de auditoría (días)
MCP_AUDIT_RETENTION_DAYS=90
